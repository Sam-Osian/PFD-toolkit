# Core Django
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=pfdtoolkit.org,www.pfdtoolkit.org
CSRF_TRUSTED_ORIGINS=https://pfdtoolkit.org,https://www.pfdtoolkit.org
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth0
AUTH0_DOMAIN=oreliandata.uk.auth0.com
AUTH0_CLIENT_ID=replace-me
AUTH0_CLIENT_SECRET=replace-me
AUTH0_SCOPES=openid profile email
AUTH0_CALLBACK_URL=https://pfdtoolkit.org/auth/callback/
AUTH0_POST_LOGOUT_REDIRECT_URI=https://pfdtoolkit.org/

# App metadata
PFD_ADMIN_EMAIL=sam.osian@oreliandata.co.uk
WORKBENCH_BASE_URL=https://pfdtoolkit.org

# Artifact storage
ARTIFACT_STORAGE_BACKEND=object_storage
ARTIFACT_ENFORCE_OBJECT_STORAGE_IN_PRODUCTION=True
ARTIFACT_OBJECT_STORAGE_BUCKET=
ARTIFACT_OBJECT_STORAGE_REGION=
ARTIFACT_OBJECT_STORAGE_ENDPOINT_URL=
ARTIFACT_OBJECT_STORAGE_ACCESS_KEY_ID=
ARTIFACT_OBJECT_STORAGE_SECRET_ACCESS_KEY=
ARTIFACT_OBJECT_STORAGE_PREFIX=workbench-artifacts
ARTIFACT_STORAGE_DELETE_LOCAL_AFTER_UPLOAD=True
ARTIFACT_RETENTION_DAYS=365
ARTIFACT_SOFT_DELETE_DAYS=30
ARTIFACT_VERIFY_CHECKSUM=True

# Lifecycle maintenance
LIFECYCLE_INACTIVITY_DAYS=365
LIFECYCLE_ARCHIVE_RETENTION_DAYS=60
LIFECYCLE_VIEW_DEBOUNCE_SECONDS=0

# Notifications (Brevo SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=replace-me
DEFAULT_FROM_EMAIL=noreply@pfdtoolkit.org

# Run guardrails
RUN_GUARDRAILS_ENABLED=True
MAX_RUNS_PER_USER_PER_DAY=20
MAX_RUNS_PER_WORKBOOK_PER_DAY=40
MAX_CONCURRENT_RUNS_PER_USER=2
MAX_CONCURRENT_RUNS_GLOBAL=12
RUN_LAUNCH_RATE_LIMIT_USER_PER_MINUTE=10
RUN_LAUNCH_RATE_LIMIT_IP_PER_MINUTE=30

# Run reliability
RUN_RETRY_ENABLED=True
RUN_RETRY_MAX_ATTEMPTS=3
RUN_RETRY_BACKOFF_SECONDS=30,120,600
RUN_RETRY_JITTER_PCT=20
RUN_STAGE_TIMEOUT_SECONDS=1800
RUN_TOTAL_TIMEOUT_SECONDS=7200
RUN_STUCK_THRESHOLD_SECONDS=1800
WORKER_HEARTBEAT_STALE_SECONDS=120

# Optional credential encryption override
CREDENTIAL_ENCRYPTION_KEY=

# Performance instrumentation
PERF_REQUEST_LOGGING_ENABLED=True
PERF_SLOW_REQUEST_MS=800
PERF_SLOW_QUERY_MS=200
PERF_ADD_RESPONSE_TIMING_HEADER=False
